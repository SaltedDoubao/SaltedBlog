# ============================================
# SaltedBlog 环境变量示例
# 本地开发：复制为仓库根目录 .env（Rust API 会自动向上查找加载）
# Docker 部署：复制为 deploy/.env，由 docker-compose.yml 引用
# ============================================

# ---- 数据库 ----
# 本地开发默认使用 SQLite（文件位于 data/blog.db，自动创建）
DATABASE_URL=sqlite://data/blog.db?mode=rwc
# Docker / 生产使用 PostgreSQL 时形如：
# DATABASE_URL=postgres://salted:salted@postgres:5432/saltedblog

# ---- Rust API ----
APP_ENV=development
BIND_ADDR=0.0.0.0:8787
# 上传文件保存目录（相对仓库根目录或绝对路径）
UPLOAD_DIR=data/uploads
# 单文件上传大小上限（MB）
UPLOAD_MAX_MB=20
# 备份目录（相对仓库根目录或绝对路径）
BACKUP_DIR=backups
# 自动保留最近 N 份备份
BACKUP_KEEP=7
# 本机上传备份 zip 大小上限（MB）
BACKUP_UPLOAD_MAX_MB=1024
# 管理会话：闲置超时、绝对超时、高危操作二次验证有效期
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=12
STEP_UP_MINUTES=5
# 生产环境走 HTTPS 时设为 true（Cookie 增加 Secure 标记）
COOKIE_SECURE=false
# 浏览器管理端唯一合法来源；生产环境必须为私网管理域名 HTTPS
ADMIN_ORIGIN=http://localhost:4321
# 仅信任这些直接反向代理网段传入的 X-Forwarded-For，逗号分隔
TRUSTED_PROXY_CIDRS=
# 生产强制 TOTP；两个密钥应使用独立的 32 字节随机值
MFA_REQUIRED=false
MFA_ENCRYPTION_KEY=
BACKUP_SIGNING_KEY=
# 统计使用的时区偏移（小时），北京时间为 8
STATS_TZ_OFFSET_HOURS=8
# 日志级别
RUST_LOG=info,sqlx=warn

# ---- 管理员引导账号（仅在 users 表为空时创建）----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=please-change-me

# ---- AI 情报日报（可选）----
# OpenAI 兼容服务的 API Key（DeepSeek / 硅基流动 / OpenRouter 等均可）。
# base_url、模型名、调度时间等在后台「情报管理」页配置；Key 仅走环境变量不落库。
NEWS_LLM_API_KEY=

# ---- Astro Web (SSR) ----
# SSR 服务端访问 API 的内部地址（Docker 中为 http://api:8787）
API_URL=http://127.0.0.1:8787
# 站点对外地址，用于 canonical / RSS / sitemap 绝对链接
PUBLIC_SITE_URL=http://localhost:4321
# Web 服务监听端口（node adapter）
PORT=4321

# ---- Docker Compose 专用 ----
# 你的域名（Caddy 自动申请 HTTPS 证书）
SITE_DOMAIN=example.com
ADMIN_DOMAIN=admin.internal
# Caddy 外层代理的真实 CIDR，空格分隔；后台域名不得经该代理转发
UPSTREAM_PROXY_CIDRS=127.0.0.1/32
ADMIN_ALLOWED_CIDRS=10.8.0.0/24
POSTGRES_SUPERUSER=salted_admin
POSTGRES_DB=saltedblog
