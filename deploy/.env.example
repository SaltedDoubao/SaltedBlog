# SaltedBlog Docker Compose 部署配置示例
# 复制为 deploy/.env；从仓库根目录使用 --env-file ./deploy/.env 启动。
# 此文件仅包含非敏感的 Compose 插值变量。密码、密钥和 URL 凭据只放在 deploy/secrets/。

# 已发布的 GHCR 镜像版本。生产环境必须替换为已验证的 v* 标签或 sha-<完整提交 SHA>。
SALTEDBLOG_IMAGE_TAG=v0.1.3

# 公网站点与管理站点域名
SITE_DOMAIN=blog.example.com
ADMIN_DOMAIN=admin.example.com

# 网络边界：不得使用 0.0.0.0/0。
# 公开站点直连 Caddy 时保留 127.0.0.1/32；使用外层代理时填其精确 CIDR。
UPSTREAM_PROXY_CIDRS=127.0.0.1/32
# VPN 部署填写实际 VPN 客户端网段；Cloudflare Tunnel 部署填写 172.30.0.40/32。
ADMIN_ALLOWED_CIDRS=10.8.0.0/24

# PostgreSQL 非敏感标识。账号密码通过 deploy/secrets/ 提供。
POSTGRES_SUPERUSER=salted_admin
POSTGRES_DB=saltedblog

# 可选运行参数
UPLOAD_MAX_MB=20
BACKUP_KEEP=7
BACKUP_UPLOAD_MAX_MB=1024
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=12
STEP_UP_MINUTES=5
STATS_TZ_OFFSET_HOURS=8
