---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getArchive } from '@/lib/api';
import { formatDate, localePath, t, type Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const { items } = await getArchive();

const groups = new Map<string, typeof items>();
for (const item of items) {
  const year = item.published_at ? String(new Date(item.published_at).getFullYear()) : '—';
  if (!groups.has(year)) groups.set(year, []);
  groups.get(year)!.push(item);
}
const years = Array.from(groups.keys());
---

<BaseLayout lang={lang} title={t(lang, 'archive.title')}>
  <section class="page-section">
    <div class="watermark" aria-hidden="true">ARCHIVE</div>
    <div class="container">
      <header class="section-heading rise-in">
        <span class="section-heading__eyebrow">{t(lang, 'archive.eyebrow')}</span>
        <h1 class="section-heading__title">{t(lang, 'archive.title')}</h1>
        <div class="archive-total mono">
          {t(lang, 'archive.total')} {String(items.length).padStart(2, '0')} {t(lang, 'archive.unit')}
        </div>
      </header>

      {items.length === 0 && <div class="empty-state mono">NO SIGNAL / EMPTY ARCHIVE</div>}

      {
        years.map((year) => (
          <section class="archive-year">
            <h2 class="archive-year__label" data-year={year}>
              {year}
              <span class="mono">/ {String(groups.get(year)!.length).padStart(2, '0')}</span>
            </h2>
            <ol class="archive-list">
              {groups.get(year)!.map((item) => (
                <li>
                  <a class="archive-item" href={localePath(lang, `/posts/${item.slug}`)}>
                    <span class="archive-item__date mono">
                      {formatDate(lang, item.published_at).slice(5)}
                    </span>
                    <span class="archive-item__title">{item.title}</span>
                    <span class="archive-item__views mono">
                      {item.view_count} {t(lang, 'post.views')}
                    </span>
                  </a>
                </li>
              ))}
            </ol>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .page-section {
    position: relative;
    padding: var(--space-20) 0;
    overflow: hidden;
  }

  .archive-total {
    margin-top: var(--space-4);
    font-size: 11px;
    color: var(--text-3);
  }

  .archive-year {
    max-width: 860px;
    margin-bottom: var(--space-12);
  }

  .archive-year__label {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    margin: 0 0 var(--space-5);
    font-family: var(--font-display);
    font-size: clamp(34px, 4vw, 52px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    user-select: none;
  }

  .archive-year__label span {
    font-size: 12px;
    color: var(--text-3);
  }

  .archive-list {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--border);
  }

  .archive-item {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    align-items: baseline;
    gap: var(--space-4);
    padding: 13px var(--space-2);
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: var(--text);
    transition: background-color var(--duration-fast) var(--ease);
  }

  .archive-item:hover {
    background: var(--surface);
  }

  .archive-item:hover .archive-item__title {
    background: var(--primary);
    color: var(--black);
  }

  .archive-item__date {
    font-size: 11px;
    color: var(--text-3);
  }

  .archive-item__title {
    font-size: 15.5px;
    font-weight: 600;
    line-height: 1.5;
  }

  .archive-item__views {
    font-size: 9px;
    color: var(--text-3);
  }

  @media (max-width: 520px) {
    .archive-item {
      grid-template-columns: 48px 1fr;
    }
    .archive-item__views {
      display: none;
    }
  }
</style>
