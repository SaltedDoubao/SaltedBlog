</style>

<script>
  (() => {
    const home = document.getElementById('homeInterface');
    if (!home) return;

    const root = document.documentElement;
    const body = document.body;
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const boot = document.getElementById('homeBoot');
    const bootFill = document.getElementById('homeBootFill') as HTMLElement | null;
    const bootCount = document.getElementById('homeBootCount');

    const revealInitial = () => {
      home.querySelectorAll<HTMLElement>('.hero [data-reveal]').forEach((element, index) => {
        setTimeout(() => element.classList.add('is-visible'), reduced ? 0 : index * 125);
      });
    };

    if (!reduced && root.dataset.homeBoot === 'play' && boot && bootFill && bootCount) {
      let value = 0;
      const tick = () => {
        value += Math.max(1, Math.round((101 - value) * 0.075));
        value = Math.min(value, 100);
        bootFill.style.width = `${value}%`;
        bootCount.textContent = `${String(value).padStart(3, '0')}%`;
        if (value < 100) {
          requestAnimationFrame(tick);
        } else {
          setTimeout(() => {
            boot.classList.add('is-done');
            root.dataset.homeBoot = 'done';
            try { sessionStorage.setItem('sb-home-booted', '1'); } catch (_) {}
            revealInitial();
            setTimeout(() => boot.remove(), 720);
          }, 320);
        }
      };
      setTimeout(tick, 180);
    } else {
      root.dataset.homeBoot = 'skip';
      boot?.remove();
      revealInitial();
    }

    const revealElements = home.querySelectorAll<HTMLElement>('main [data-reveal], [data-reveal]');
    if (reduced || !('IntersectionObserver' in window)) {
      revealElements.forEach((element) => element.classList.add('is-visible'));
    } else {
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          (entry.target as HTMLElement).classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -7%' });
      revealElements.forEach((element) => {
        if (!element.closest('.hero')) revealObserver.observe(element);
      });
    }

    const newsCarousel = home.querySelector<HTMLElement>('[data-news-carousel]');
    if (newsCarousel) {
      const slides = Array.from(newsCarousel.querySelectorAll<HTMLElement>('[data-news-slide]'));
      const dots = Array.from(newsCarousel.querySelectorAll<HTMLButtonElement>('[data-news-dot]'));
      let activeIndex = 0;
      let paused = false;
      let timer: number | null = null;

      const showSlide = (next: number) => {
        if (slides.length < 2) return;
        activeIndex = (next + slides.length) % slides.length;
        slides.forEach((slide, index) => {
          const active = index === activeIndex;
          slide.hidden = !active;
          slide.dataset.active = String(active);
          slide.inert = !active;
        });
        dots.forEach((dot, index) => {
          const active = index === activeIndex;
          dot.dataset.active = String(active);
          if (active) dot.setAttribute('aria-current', 'true');
          else dot.removeAttribute('aria-current');
        });
      };

      const stopCarousel = () => {
        if (timer !== null) window.clearInterval(timer);
        timer = null;
      };
      const startCarousel = () => {
        stopCarousel();
        if (reduced || slides.length < 2) return;
        timer = window.setInterval(() => {
          if (!paused && !document.hidden) showSlide(activeIndex + 1);
        }, 5000);
      };
      const manualMove = (next: number) => {
        showSlide(next);
        startCarousel();
      };

      newsCarousel.querySelector<HTMLButtonElement>('[data-news-prev]')?.addEventListener('click', () => manualMove(activeIndex - 1));
      newsCarousel.querySelector<HTMLButtonElement>('[data-news-next]')?.addEventListener('click', () => manualMove(activeIndex + 1));
      dots.forEach((dot, index) => dot.addEventListener('click', () => manualMove(index)));
      newsCarousel.addEventListener('mouseenter', () => { paused = true; });
      newsCarousel.addEventListener('mouseleave', () => { paused = false; });
      newsCarousel.addEventListener('focusin', () => { paused = true; });
      newsCarousel.addEventListener('focusout', (event) => {
        if (!newsCarousel.contains(event.relatedTarget as Node | null)) paused = false;
      });
      showSlide(0);
      startCarousel();
      window.addEventListener('pagehide', stopCarousel, { once: true });
    }

    const heroSection = home.querySelector<HTMLElement>('.hero');
    const ticker = home.querySelector<HTMLElement>('.ticker');
    const world = document.getElementById('home-world');
    const finalCta = home.querySelector<HTMLElement>('.final-cta');
    const worldTrack = document.getElementById('worldTrack') as HTMLElement | null;
    const worldProgress = document.getElementById('worldProgress') as HTMLElement | null;
    let heroVisible = true;
    let radarVisible = false;
    let worldVisible = false;

    const motionObserver = !reduced && 'IntersectionObserver' in window
      ? new IntersectionObserver((entries) => entries.forEach((entry) => {
          const element = entry.target as HTMLElement;
          element.classList.toggle('is-motion-active', entry.isIntersecting);
          if (element === world) worldVisible = entry.isIntersecting;
        }), { rootMargin: '160px 0px', threshold: 0 })
      : null;
    [heroSection, ticker, world, finalCta].forEach((element) => {
      if (!element) return;
      if (motionObserver) motionObserver.observe(element);
      else element.classList.add('is-motion-active');
    });

    const pointerFine = matchMedia('(hover: hover) and (pointer: fine)').matches;
    const dot = document.getElementById('homeCursorDot') as HTMLElement | null;
    const ring = document.getElementById('homeCursorRing') as HTMLElement | null;
    let pointerX = innerWidth / 2;
    let pointerY = innerHeight / 2;
    let ringX = pointerX;
    let ringY = pointerY;
    let cursorRaf: number | null = null;
    const drawCursor = () => {
      cursorRaf = null;
      if (!ring || document.hidden) return;
      ringX += (pointerX - ringX) * 0.18;
      ringY += (pointerY - ringY) * 0.18;
      ring.style.transform = `translate3d(${ringX}px,${ringY}px,0) translate(-50%,-50%)`;
      if (Math.abs(pointerX - ringX) > 0.15 || Math.abs(pointerY - ringY) > 0.15) {
        cursorRaf = requestAnimationFrame(drawCursor);
      }
    };
    const scheduleCursor = () => {
      if (cursorRaf === null && !document.hidden) cursorRaf = requestAnimationFrame(drawCursor);
    };
    if (pointerFine && !reduced && dot && ring) {
      addEventListener('pointermove', (event) => {
        pointerX = event.clientX;
        pointerY = event.clientY;
        const mx = (((event.clientX / innerWidth) - 0.5)).toFixed(3);
        const my = (((event.clientY / innerHeight) - 0.5)).toFixed(3);
        if (heroVisible) {
          heroSection?.style.setProperty('--mx', mx);
          heroSection?.style.setProperty('--my', my);
        }
        if (worldVisible) {
          world?.style.setProperty('--mx', mx);
          world?.style.setProperty('--my', my);
        }
        dot.style.transform = `translate3d(${pointerX}px,${pointerY}px,0) translate(-50%,-50%)`;
        scheduleCursor();
      }, { passive: true });
      home.querySelectorAll('a,button,.interactive').forEach((element) => {
        element.addEventListener('mouseenter', () => ring.classList.add('is-active'));
        element.addEventListener('mouseleave', () => ring.classList.remove('is-active'));
      });
    }

    const updateWorld = () => {
      if (heroVisible) heroSection?.style.setProperty('--scroll', Math.min(scrollY, innerHeight * 1.5).toFixed(1));
      if (!world || !worldTrack || !worldProgress || innerWidth <= 820 || reduced) {
        if (worldTrack) worldTrack.style.transform = 'none';
        if (worldProgress) worldProgress.style.transform = 'scaleX(0)';
        return;
      }
      const rect = world.getBoundingClientRect();
      const available = world.offsetHeight - innerHeight;
      const progress = Math.min(1, Math.max(0, -rect.top / available));
      worldTrack.style.transform = `translate3d(${-progress * 200}vw,0,0)`;
      worldProgress.style.transform = `scaleX(${progress})`;
    };
    let scrollRaf: number | null = null;
    const scheduleScrollUpdate = () => {
      if (scrollRaf !== null) return;
      scrollRaf = requestAnimationFrame(() => {
        scrollRaf = null;
        updateWorld();
      });
    };
    addEventListener('scroll', scheduleScrollUpdate, { passive: true });
    addEventListener('resize', scheduleScrollUpdate, { passive: true });
    updateWorld();

    const counters = home.querySelectorAll<HTMLElement>('.counter');
    let counterObserver: IntersectionObserver | null = null;
    if (reduced || !('IntersectionObserver' in window)) {
      counters.forEach((counter) => { counter.textContent = counter.dataset.value || '0'; });
    } else {
      counterObserver = new IntersectionObserver((entries) => entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const element = entry.target as HTMLElement;
        const target = Number(element.dataset.value || 0);
        const start = performance.now();
        const animate = (now: number) => {
          const progress = Math.min(1, (now - start) / 1100);
          element.textContent = String(Math.round(target * (1 - Math.pow(1 - progress, 3))));
          if (progress < 1) requestAnimationFrame(animate);
        };
        requestAnimationFrame(animate);
        counterObserver?.unobserve(element);
      }), { threshold: 0.5 });
      counters.forEach((counter) => counterObserver?.observe(counter));
    }

    const fitCanvas = (
      canvas: HTMLCanvasElement,
      context: CanvasRenderingContext2D,
      maxPixels: number,
    ) => {
      const logicalWidth = Math.max(1, Math.round(canvas.clientWidth));
      const logicalHeight = Math.max(1, Math.round(canvas.clientHeight));
      const requestedScale = Math.min(devicePixelRatio || 1, 1.5);
      const pixelScale = Math.sqrt(maxPixels / (logicalWidth * logicalHeight));
      const scale = Math.min(requestedScale, pixelScale);
      const targetWidth = Math.max(1, Math.round(logicalWidth * scale));
      const targetHeight = Math.max(1, Math.round(logicalHeight * scale));
      const changed = canvas.width !== targetWidth || canvas.height !== targetHeight;
      if (changed) {
        canvas.width = targetWidth;
        canvas.height = targetHeight;
        context.setTransform(scale, 0, 0, scale, 0, 0);
      }
      canvas.dataset.bufferPixels = String(targetWidth * targetHeight);
      return { logicalWidth, logicalHeight, changed };
    };

    const heroCanvas = document.getElementById('heroCanvas') as HTMLCanvasElement | null;
    const heroContext = heroCanvas?.getContext('2d', { desynchronized: true });
    let heroWidth = 0;
    let heroHeight = 0;
    let heroRaf: number | null = null;
    let heroResizeRaf: number | null = null;
    let lastHeroFrame = 0;
    let particles: Array<{ x: number; y: number; vx: number; vy: number; r: number }> = [];
    const resizeHero = () => {
      heroResizeRaf = null;
      if (!heroCanvas || !heroContext) return;
      const fitted = fitCanvas(heroCanvas, heroContext, 2_000_000);
      heroWidth = fitted.logicalWidth;
      heroHeight = fitted.logicalHeight;
      if (fitted.changed || particles.length === 0) {
        particles = Array.from({ length: Math.min(56, Math.floor(heroWidth / 24)) }, () => ({
          x: Math.random() * heroWidth,
          y: Math.random() * heroHeight,
          vx: (Math.random() - 0.5) * 0.15,
          vy: (Math.random() - 0.5) * 0.15,
          r: Math.random() * 1.4 + 0.35,
        }));
      }
    };
    const scheduleHeroResize = () => {
      if (heroResizeRaf === null) heroResizeRaf = requestAnimationFrame(resizeHero);
    };
    const heroShouldRun = () => Boolean(heroContext && heroCanvas && heroVisible && !document.hidden && !reduced);
    const drawHero = (stamp: number) => {
      heroRaf = null;
      if (!heroContext || !heroCanvas || !heroShouldRun()) return;
      if (lastHeroFrame && stamp - lastHeroFrame < 32) {
        heroRaf = requestAnimationFrame(drawHero);
        return;
      }
      const step = lastHeroFrame ? Math.min(2.5, (stamp - lastHeroFrame) / 16.67) : 1;
      lastHeroFrame = stamp;
      heroContext.clearRect(0, 0, heroWidth, heroHeight);
      heroContext.strokeStyle = 'rgba(244,246,0,.12)';
      heroContext.lineWidth = 0.65;
      particles.forEach((particle, index) => {
        particle.x += particle.vx * step;
        particle.y += particle.vy * step;
        if (particle.x < 0 || particle.x > heroWidth) particle.vx *= -1;
        if (particle.y < 0 || particle.y > heroHeight) particle.vy *= -1;
        heroContext.fillStyle = 'rgba(244,246,0,.42)';
        heroContext.beginPath();
        heroContext.arc(particle.x, particle.y, particle.r, 0, Math.PI * 2);
        heroContext.fill();
        for (let next = index + 1; next < particles.length; next += 1) {
          const other = particles[next];
          const distance = Math.hypot(particle.x - other.x, particle.y - other.y);
          if (distance < 115) {
            heroContext.globalAlpha = (1 - distance / 115) * 0.45;
            heroContext.beginPath();
            heroContext.moveTo(particle.x, particle.y);
            heroContext.lineTo(other.x, other.y);
            heroContext.stroke();
            heroContext.globalAlpha = 1;
          }
        }
      });
      heroRaf = requestAnimationFrame(drawHero);
    };
    const syncHeroLoop = () => {
      if (heroShouldRun()) {
        if (heroCanvas) heroCanvas.dataset.rendering = 'true';
        if (heroRaf === null) {
          lastHeroFrame = 0;
          heroRaf = requestAnimationFrame(drawHero);
        }
      } else if (heroRaf !== null) {
        cancelAnimationFrame(heroRaf);
        heroRaf = null;
        if (heroCanvas) heroCanvas.dataset.rendering = 'false';
      } else if (heroCanvas) {
        heroCanvas.dataset.rendering = 'false';
      }
    };
    const heroObserver = heroCanvas && !reduced
      ? new IntersectionObserver(([entry]) => {
          heroVisible = entry.isIntersecting;
          if (heroVisible) resizeHero();
          syncHeroLoop();
        }, { rootMargin: '160px 0px', threshold: 0 })
      : null;
    const heroResizeObserver = heroCanvas && 'ResizeObserver' in window
      ? new ResizeObserver(scheduleHeroResize)
      : null;
    if (heroCanvas && heroContext && !reduced) {
      resizeHero();
      heroObserver?.observe(heroCanvas);
      heroResizeObserver?.observe(heroCanvas);
      syncHeroLoop();
    }

    const radarCanvas = document.getElementById('radarCanvas') as HTMLCanvasElement | null;
    const radarContext = radarCanvas?.getContext('2d', { alpha: false, desynchronized: true });
    let radarWidth = 0;
    let radarHeight = 0;
    let radarMode = 'network';
    let radarRaf: number | null = null;
    let radarResizeRaf: number | null = null;
    let lastRadarFrame = 0;
    const radarNodes = Array.from({ length: 16 }, (_, index) => ({
      angle: Math.random() * Math.PI * 2,
      radius: 0.12 + Math.random() * 0.35,
      speed: 0.15 + Math.random() * 0.25,
      phase: index % 3,
    }));
    const resizeRadar = () => {
      radarResizeRaf = null;
      if (!radarCanvas || !radarContext || !radarVisible) return;
      const fitted = fitCanvas(radarCanvas, radarContext, 750_000);
      radarWidth = fitted.logicalWidth;
      radarHeight = fitted.logicalHeight;
    };
    const scheduleRadarResize = () => {
      if (radarResizeRaf === null && radarVisible) radarResizeRaf = requestAnimationFrame(resizeRadar);
    };
    const radarShouldRun = () => Boolean(radarCanvas && radarContext && radarVisible && !document.hidden && !reduced);
    const drawRadar = (stamp: number) => {
      radarRaf = null;
      if (!radarCanvas || !radarContext || !radarShouldRun()) return;
      if (lastRadarFrame && stamp - lastRadarFrame < 32) {
        radarRaf = requestAnimationFrame(drawRadar);
        return;
      }
      lastRadarFrame = stamp;
      const time = stamp * 0.0003;
      radarContext.clearRect(0, 0, radarWidth, radarHeight);
      radarContext.fillStyle = '#151a1c';
      radarContext.fillRect(0, 0, radarWidth, radarHeight);
      const centerX = radarWidth * 0.5;
      const centerY = radarHeight * 0.5;
      const radius = Math.min(radarWidth, radarHeight) * 0.37;
      radarContext.strokeStyle = 'rgba(255,255,255,.1)';
      radarContext.lineWidth = 1;
      for (let ringIndex = 1; ringIndex <= 5; ringIndex += 1) {
        radarContext.beginPath();
        radarContext.arc(centerX, centerY, radius * ringIndex / 5, 0, Math.PI * 2);
        radarContext.stroke();
      }
      for (let ray = 0; ray < 12; ray += 1) {
        const angle = ray * Math.PI / 6;
        radarContext.beginPath();
        radarContext.moveTo(centerX, centerY);
        radarContext.lineTo(centerX + Math.cos(angle) * radius, centerY + Math.sin(angle) * radius);
        radarContext.stroke();
      }
      const sweep = time % (Math.PI * 2);
      const gradient = radarContext.createRadialGradient(centerX, centerY, 0, centerX, centerY, radius);
      gradient.addColorStop(0, 'rgba(244,246,0,.18)');
      gradient.addColorStop(1, 'rgba(244,246,0,0)');
      radarContext.save();
      radarContext.translate(centerX, centerY);
      radarContext.rotate(sweep);
      radarContext.beginPath();
      radarContext.moveTo(0, 0);
      radarContext.arc(0, 0, radius, -0.18, 0);
      radarContext.closePath();
      radarContext.fillStyle = gradient;
      radarContext.fill();
      radarContext.strokeStyle = 'rgba(244,246,0,.72)';
      radarContext.beginPath();
      radarContext.moveTo(0, 0);
      radarContext.lineTo(radius, 0);
      radarContext.stroke();
      radarContext.restore();
      const points = radarNodes.map((node) => ({
        x: centerX + Math.cos(node.angle + time * node.speed) * radius * node.radius * 2,
        y: centerY + Math.sin(node.angle + time * node.speed) * radius * node.radius * 2,
        phase: node.phase,
      }));
      if (radarMode !== 'scan') {
        radarContext.strokeStyle = radarMode === 'taxonomy' ? 'rgba(255,255,255,.18)' : 'rgba(244,246,0,.18)';
        for (let from = 0; from < points.length; from += 1) for (let to = from + 1; to < points.length; to += 1) {
          const distance = Math.hypot(points[from].x - points[to].x, points[from].y - points[to].y);
          const threshold = radarMode === 'taxonomy' ? 160 : 120;
          if (distance < threshold) {
            radarContext.globalAlpha = 1 - distance / 180;
            radarContext.beginPath();
            radarContext.moveTo(points[from].x, points[from].y);
            radarContext.lineTo(points[to].x, points[to].y);
            radarContext.stroke();
          }
        }
        radarContext.globalAlpha = 1;
      }
      points.forEach((point, index) => {
        const active = Math.abs(Math.atan2(point.y - centerY, point.x - centerX) - sweep) < 0.08;
        radarContext.fillStyle = active || index % 4 === 0 ? '#f4f600' : 'rgba(255,255,255,.6)';
        radarContext.fillRect(point.x - 2, point.y - 2, active ? 7 : 4, active ? 7 : 4);
      });
      radarContext.fillStyle = 'rgba(255,255,255,.55)';
      radarContext.font = '10px monospace';
      radarContext.fillText(`SALTEDBLOG / ${radarMode.toUpperCase()}`, 28, 38);
      radarContext.fillText(`SIGNAL ${String(Math.floor((Math.sin(time) * 0.5 + 0.5) * 99)).padStart(2, '0')}%`, 28, radarHeight - 30);
      radarRaf = requestAnimationFrame(drawRadar);
    };
    const syncRadarLoop = () => {
      if (radarShouldRun()) {
        if (radarCanvas) radarCanvas.dataset.rendering = 'true';
        if (radarRaf === null) {
          lastRadarFrame = 0;
          radarRaf = requestAnimationFrame(drawRadar);
        }
      } else if (radarRaf !== null) {
        cancelAnimationFrame(radarRaf);
        radarRaf = null;
        if (radarCanvas) radarCanvas.dataset.rendering = 'false';
      } else if (radarCanvas) {
        radarCanvas.dataset.rendering = 'false';
      }
    };
    const radarObserver = radarCanvas && !reduced
      ? new IntersectionObserver(([entry]) => {
          radarVisible = entry.isIntersecting;
          if (radarVisible) resizeRadar();
          syncRadarLoop();
        }, { rootMargin: '160px 0px', threshold: 0 })
      : null;
    const radarResizeObserver = radarCanvas && 'ResizeObserver' in window
      ? new ResizeObserver(scheduleRadarResize)
      : null;
    if (radarCanvas && radarContext && !reduced) {
      radarObserver?.observe(radarCanvas);
      radarResizeObserver?.observe(radarCanvas);
    }

    const handleVisibilityChange = () => {
      home.classList.toggle('is-page-hidden', document.hidden);
      if (document.hidden && cursorRaf !== null) {
        cancelAnimationFrame(cursorRaf);
        cursorRaf = null;
      }
      syncHeroLoop();
      syncRadarLoop();
    };
    document.addEventListener('visibilitychange', handleVisibilityChange);

    const systemAction = document.getElementById('systemAction') as HTMLAnchorElement | null;
    home.querySelectorAll<HTMLButtonElement>('.system-tab').forEach((tab) => tab.addEventListener('click', () => {
      home.querySelectorAll<HTMLButtonElement>('.system-tab').forEach((item) => {
        const selected = item === tab;
        item.classList.toggle('is-active', selected);
        item.setAttribute('aria-selected', String(selected));
      });
      radarMode = tab.dataset.mode || 'network';
      if (systemAction) {
        systemAction.href = tab.dataset.actionHref || '#';
        systemAction.textContent = `${tab.dataset.actionLabel || ''} ↗`;
      }
    }));

    const operatorMain = document.getElementById('operatorMain') as HTMLElement | null;
    const operatorName = document.getElementById('operatorName');
    const operatorRole = document.getElementById('operatorRole');
    const operatorDesc = document.getElementById('operatorDesc');
    const operatorAction = document.getElementById('operatorAction') as HTMLAnchorElement | null;
    home.querySelectorAll<HTMLButtonElement>('.operator-btn').forEach((button) => button.addEventListener('click', () => {
      home.querySelectorAll<HTMLButtonElement>('.operator-btn').forEach((item) => {
        const selected = item === button;
        item.classList.toggle('is-active', selected);
        item.setAttribute('aria-selected', String(selected));
      });
      operatorMain?.animate(
        [{ opacity: 0.45, transform: 'translateX(14px)' }, { opacity: 1, transform: 'none' }],
        { duration: reduced ? 1 : 420, easing: 'cubic-bezier(.2,.8,.2,1)' },
      );
      if (operatorMain) operatorMain.dataset.op = button.dataset.op || '1';
      if (operatorName) operatorName.textContent = button.dataset.name || '';
      if (operatorRole) operatorRole.textContent = button.dataset.role || '';
      if (operatorDesc) operatorDesc.textContent = button.dataset.desc || '';
      if (operatorAction) {
        operatorAction.href = button.dataset.href || '#';
        operatorAction.textContent = `${button.dataset.action || ''} ↗`;
      }
    }));

    const modal = document.getElementById('protocolModal');
    const modalClose = document.getElementById('protocolClose') as HTMLButtonElement | null;
    let modalOpener: HTMLElement | null = null;
    let modalIdleTimer: number | null = null;
    const modalFocusables = () => Array.from(modal?.querySelectorAll<HTMLElement>('button,a[href]') || []);
    const openModal = (opener: HTMLElement) => {
      if (!modal) return;
      if (modalIdleTimer !== null) {
        clearTimeout(modalIdleTimer);
        modalIdleTimer = null;
      }
      modalOpener = opener;
      modal.classList.remove('is-idle');
      modal.setAttribute('aria-hidden', 'false');
      body.classList.add('is-locked');
      requestAnimationFrame(() => {
        modal.classList.add('is-open');
        requestAnimationFrame(() => modalClose?.focus({ preventScroll: true }));
      });
    };
    const closeModal = () => {
      if (!modal?.classList.contains('is-open')) return;
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      body.classList.remove('is-locked');
      modalIdleTimer = window.setTimeout(() => {
        modal.classList.add('is-idle');
        modalIdleTimer = null;
      }, 360);
      modalOpener?.focus();
    };
    home.querySelectorAll<HTMLElement>('[data-open-protocol]').forEach((button) => button.addEventListener('click', () => openModal(button)));
    modalClose?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (event) => { if (event.target === modal) closeModal(); });
    addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeModal();
      if (event.key !== 'Tab' || !modal?.classList.contains('is-open')) return;
      const focusables = modalFocusables();
      if (!focusables.length) return;
      const first = focusables[0];
      const last = focusables[focusables.length - 1];
      if (event.shiftKey && document.activeElement === first) { event.preventDefault(); last.focus(); }
      else if (!event.shiftKey && document.activeElement === last) { event.preventDefault(); first.focus(); }
    });
    modal?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeModal));

    addEventListener('pagehide', () => {
      [cursorRaf, scrollRaf, heroRaf, heroResizeRaf, radarRaf, radarResizeRaf].forEach((id) => {
        if (id !== null) cancelAnimationFrame(id);
      });
      if (modalIdleTimer !== null) clearTimeout(modalIdleTimer);
      motionObserver?.disconnect();
      counterObserver?.disconnect();
      heroObserver?.disconnect();
      heroResizeObserver?.disconnect();
      radarObserver?.disconnect();
      radarResizeObserver?.disconnect();
      document.removeEventListener('visibilitychange', handleVisibilityChange);
    }, { once: true });
  })();
</script>
