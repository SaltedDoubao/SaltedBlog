  .news-card__art--2 { background: repeating-linear-gradient(115deg,transparent 0 24px,rgba(244,246,0,.75) 25px 28px),radial-gradient(circle at 35% 42%,#bbc3c1 0 13%,transparent 13.5%),linear-gradient(145deg,#242a2d,#899292); }
