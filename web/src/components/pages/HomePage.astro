  .terrain--front { width: 74vw; height: 38vh; left: -7vw; bottom: -9vh; opacity: .93; background: #111719; clip-path: polygon(0 42%,18% 8%,36% 45%,54% 20%,70% 50%,88% 14%,100% 55%,100% 100%,0 100%); transform: translate(calc(var(--mx, 0) * -20px), calc(var(--my, 0) * -5px)); }
  .hero__wash { position: absolute; inset: 0; z-index: -2; background: linear-gradient(90deg,rgba(11,13,15,.84) 0,rgba(11,13,15,.47) 36%,transparent 68%), linear-gradient(0deg,rgba(11,13,15,.65),transparent 42%); }
  .hero__grid { position: absolute; inset: 0; z-index: -1; opacity: .23; background-image: linear-gradient(rgba(255,255,255,.13) 1px,transparent 1px), linear-gradient(90deg,rgba(255,255,255,.13) 1px,transparent 1px); background-size: 6.25vw 6.25vw; mask-image: linear-gradient(90deg,#000,transparent 78%); }
  .hero__content { min-height: 100svh; padding-top: calc(var(--header-h) + 80px); padding-bottom: 70px; display: grid; grid-template-columns: minmax(0,780px) 1fr; align-items: center; position: relative; }
  .hero__copy { transform: translateY(calc(var(--scroll, 0) * .06px)); }
  .hero__eyebrow { display: flex; align-items: center; gap: 14px; margin-bottom: 24px; font-size: 11px; user-select: none; }
  .hero__eyebrow::before { content: ''; width: 45px; height: 4px; background: var(--primary); }
  .hero h1 { margin: 0; max-width: 900px; overflow-wrap: anywhere; font-size: clamp(58px,7.7vw,124px); line-height: .79; letter-spacing: -.07em; font-weight: 950; text-transform: uppercase; text-shadow: 0 10px 34px rgba(0,0,0,.28); user-select: none; }
  .hero h1 span { display: block; margin-left: clamp(0px,5vw,86px); margin-top: 12px; color: transparent; -webkit-text-stroke: 1px rgba(255,255,255,.72); font-size: .62em; letter-spacing: -.04em; }
  .hero__desc { width: min(620px,100%); margin: 32px 0 0; padding-left: 20px; border-left: 3px solid var(--primary); color: rgba(255,255,255,.82); font-size: clamp(15px,1.25vw,19px); }
  .hero__actions { display: flex; gap: 12px; margin-top: 34px; flex-wrap: wrap; }
  .hero__side { align-self: end; justify-self: end; margin-bottom: 60px; width: 240px; display: grid; gap: 2px; }
  .hero__datum { padding: 14px 16px; border: 1px solid rgba(255,255,255,.25); background: rgba(11,13,15,.36); backdrop-filter: blur(8px); display: flex; justify-content: space-between; gap: 18px; font-size: 10px; clip-path: polygon(0 0,calc(100% - 8px) 0,100% 8px,100% 100%,0 100%); }
  .hero__datum b { color: var(--primary); }
  .hero__stamp { position: absolute; right: 0; top: 27%; width: 148px; aspect-ratio: 1; display: grid; place-items: center; border: 1px solid rgba(255,255,255,.42); border-radius: 50%; font-size: 9px; animation: rotate 16s linear infinite; animation-play-state: paused; }
  .hero__stamp::before,.hero__stamp::after { content: ''; position: absolute; inset: 12px; border: 1px dashed rgba(244,246,0,.65); border-radius: 50%; }
  .hero__stamp::after { inset: 44%; background: var(--primary); border: 0; }
  .hero__index { position: absolute; left: 48px; bottom: 22px; display: flex; align-items: flex-end; gap: 12px; color: rgba(255,255,255,.7); font-size: 9px; }
