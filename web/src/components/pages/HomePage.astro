  .home-section { position: relative; padding: 120px 0; overflow: hidden; border-top: 1px solid var(--line); }
  .home-section--grid { background: linear-gradient(var(--grid-line) 1px,transparent 1px),linear-gradient(90deg,var(--grid-line) 1px,transparent 1px),var(--paper); background-size: 32px 32px; }
  .section-watermark { position: absolute; top: 26px; right: -1vw; white-space: nowrap; color: var(--watermark); font-size: clamp(90px,16vw,260px); line-height: .8; font-weight: 900; letter-spacing: -.07em; pointer-events: none; user-select: none; }
