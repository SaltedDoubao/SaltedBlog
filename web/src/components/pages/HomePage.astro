    animation-play-state: paused !important;
  }

  .home-section {
    content-visibility: auto;
    contain-intrinsic-size: auto 1000px;
  }

  .home-boot {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: grid;
    place-items: center;
    color: #fff;
    background:
      linear-gradient(rgba(244, 246, 0, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(244, 246, 0, 0.04) 1px, transparent 1px),
