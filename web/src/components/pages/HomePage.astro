  .hero.is-motion-active .hero__stamp,.hero.is-motion-active .scroll-cue i::after { animation-play-state: running; }

  .home-btn { min-height: 52px; padding: 0 25px; border: 1px solid currentColor; border-radius: 0; display: inline-flex; gap: 13px; align-items: center; justify-content: center; background: transparent; color: inherit; text-decoration: none; cursor: pointer; font-weight: 750; position: relative; isolation: isolate; overflow: hidden; clip-path: polygon(0 0,calc(100% - 11px) 0,100% 11px,100% 100%,11px 100%,0 calc(100% - 11px)); transition: transform 180ms,box-shadow 180ms,color 180ms,border-color 180ms; }
