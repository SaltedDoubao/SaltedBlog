---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getPosts, getTaxonomy, getSettingsCached } from '@/lib/api';
import { t, localePath, type Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const [postsRes, taxonomy, settings] = await Promise.all([
  getPosts({ lang, page: 1, pageSize: 7 }),
  getTaxonomy(lang),
  getSettingsCached(),
]);

const siteTitle = settings[`site_title_${lang}`] || 'SaltedBlog';
const description = settings[`description_${lang}`] || '';
const [featured, ...rest] = postsRes.items;
const totalPosts = postsRes.total;
const totalCategories = taxonomy.categories.filter((c) => (c.count ?? 0) > 0).length;
const totalTags = taxonomy.tags.filter((tg) => (tg.count ?? 0) > 0).length;
---

<BaseLayout lang={lang}>
  <!-- HERO -->
  <section class="hero">
    <div class="hero__grid" aria-hidden="true"></div>
    <div class="hero__beam" aria-hidden="true"></div>
    <div class="container hero__content">
      <div class="hero__copy rise-in">
        <div class="hero__eyebrow mono">{t(lang, 'home.eyebrow')}</div>
        <h1 class="hero__title">
          {siteTitle}
          <span>BLOG · TERMINAL</span>
        </h1>
        {description && <p class="hero__desc">{description}</p>}
        <div class="hero__actions">
          <a class="btn btn--primary btn--cut" href={localePath(lang, '/posts')}>
            {t(lang, 'home.viewAll')} <span aria-hidden="true">↘</span>
          </a>
          <a class="btn hero__btn-ghost" href={localePath(lang, '/about')}>
            {t(lang, 'nav.about')}
          </a>
        </div>
      </div>

      <aside class="hero__side rise-in" aria-hidden="true">
        <div class="hero__datum mono">
          <span>{t(lang, 'home.stats.posts')}</span>
          <b>{String(totalPosts).padStart(2, '0')}</b>
        </div>
        <div class="hero__datum mono">
          <span>{t(lang, 'home.stats.categories')}</span>
          <b>{String(totalCategories).padStart(2, '0')}</b>
        </div>
        <div class="hero__datum mono">
          <span>{t(lang, 'home.stats.tags')}</span>
          <b>{String(totalTags).padStart(2, '0')}</b>
        </div>
        <div class="hero__datum mono">
          <span>LINK STATUS</span>
          <b>ONLINE</b>
        </div>
      </aside>
    </div>
    <div class="hero__index mono" aria-hidden="true">
      <strong>00</strong>
      <span>LANDING<br />PROTOCOL</span>
    </div>
    <div class="scroll-cue mono" aria-hidden="true">
      <span>SCROLL</span><i></i>
    </div>
  </section>

  <!-- 最新文章 -->
  <section class="section">
    <div class="watermark" aria-hidden="true">LATEST</div>
    <div class="container">
      <header class="home-heading">
        <div class="home-heading__num mono">01 / LATEST</div>
        <h2 class="home-heading__title">{t(lang, 'home.latest')}</h2>
        <p class="home-heading__meta">{t(lang, 'home.latest.sub')}</p>
      </header>

      {
        postsRes.items.length === 0 ? (
          <div class="empty-state mono">NO SIGNAL / {t(lang, 'posts.empty')}</div>
        ) : (
          <div class="home-grid">
            {featured && (
              <div class="home-grid__feature">
                <PostCard lang={lang} post={featured} index="01" />
              </div>
            )}
            {rest.map((post, i) => (
              <PostCard lang={lang} post={post} index={String(i + 2).padStart(2, '0')} />
            ))}
          </div>
        )
      }

      <div class="home-more">
        <a class="btn" href={localePath(lang, '/posts')}>
          {t(lang, 'home.viewAll')} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- HERO ---- */
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: calc(88svh - var(--header-h));
    display: flex;
    flex-direction: column;
    justify-content: center;
    background:
      radial-gradient(circle at 74% 30%, rgba(244, 246, 0, 0.14), transparent 26%),
      linear-gradient(120deg, #16191c 0%, #23282c 45%, #101315 100%);
    color: #f7f7f2;
    border-bottom: 1px solid #2e3335;
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.22;
    background-image: linear-gradient(rgba(255, 255, 255, 0.12) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.12) 1px, transparent 1px);
    background-size: 6.25vw 6.25vw;
    mask-image: linear-gradient(90deg, #000, transparent 80%);
  }

  .hero__beam {
    position: absolute;
    inset: -10%;
    z-index: -1;
    background:
      linear-gradient(115deg, transparent 0 55%, rgba(244, 246, 0, 0.75) 55.2% 55.7%, transparent 55.9%),
      linear-gradient(115deg, transparent 0 47%, rgba(255, 255, 255, 0.16) 47.2% 47.5%, transparent 47.7%);
  }

  .hero__content {
    display: grid;
    grid-template-columns: minmax(0, 760px) auto;
    align-items: center;
    gap: var(--space-10);
    padding: var(--space-20) 0;
  }

  .hero__eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: 11px;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: var(--space-5);
  }

  .hero__eyebrow::before {
    content: '';
    width: 42px;
    height: 4px;
    background: var(--primary);
  }

  .hero__title {
    margin: 0;
    font-size: clamp(46px, 7vw, 96px);
    line-height: 0.92;
    font-weight: 900;
    letter-spacing: -0.05em;
    text-transform: uppercase;
  }

  .hero__title span {
    display: block;
    margin-top: 8px;
    margin-left: clamp(0px, 4vw, 64px);
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.65);
    font-family: var(--font-display);
    font-size: 0.5em;
    letter-spacing: 0.02em;
  }

  .hero__desc {
    width: min(560px, 100%);
    margin: var(--space-8) 0 0;
    padding-left: var(--space-5);
    border-left: 3px solid var(--primary);
    font-size: clamp(15px, 1.2vw, 18px);
    color: rgba(255, 255, 255, 0.82);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-8);
    flex-wrap: wrap;
  }

  .hero__btn-ghost {
    border-color: rgba(255, 255, 255, 0.72);
    background: rgba(11, 13, 15, 0.35);
    color: #f7f7f2;
    backdrop-filter: blur(7px);
  }

  .hero__btn-ghost:hover {
    border-color: var(--primary);
    background: rgba(11, 13, 15, 0.35);
    color: var(--primary);
  }

  .hero__side {
    display: grid;
    gap: 2px;
    width: 230px;
  }

  .hero__datum {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 13px 15px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: rgba(11, 13, 15, 0.36);
    backdrop-filter: blur(8px);
    font-size: 10px;
    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 0 100%);
  }

  .hero__datum b {
    color: var(--primary);
    font-size: 13px;
  }

  .hero__index {
    position: absolute;
    left: max(24px, calc((100vw - var(--container)) / 2));
    bottom: 20px;
    display: flex;
    align-items: flex-end;
    gap: var(--space-3);
    color: rgba(255, 255, 255, 0.7);
    font-size: 9px;
  }

  .hero__index strong {
    font-size: 30px;
    color: #fff;
    line-height: 1;
  }

  .scroll-cue {
    position: absolute;
    right: max(24px, calc((100vw - var(--container)) / 2));
    bottom: 18px;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: rgba(255, 255, 255, 0.7);
    font-size: 9px;
    writing-mode: vertical-rl;
  }

  .scroll-cue i {
    width: 1px;
    height: 64px;
    background: rgba(255, 255, 255, 0.28);
    position: relative;
    overflow: hidden;
  }

  .scroll-cue i::after {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 22px;
    background: var(--primary);
    animation: scroll-cue 1.8s ease-in-out infinite;
  }

  @keyframes scroll-cue {
    0% {
      transform: translateY(-100%);
    }
    50%,
    100% {
      transform: translateY(320%);
    }
  }

  /* ---- 最新文章 ---- */
  .section {
    position: relative;
    padding: var(--space-24) 0;
    overflow: hidden;
  }

  .home-heading {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-6);
    align-items: end;
    margin-bottom: var(--space-12);
    position: relative;
    z-index: 1;
  }

  .home-heading__num {
    font-size: 12px;
    padding-bottom: 8px;
    border-bottom: 4px solid var(--primary);
    color: var(--text-2);
  }

  .home-heading__title {
    margin: 0;
    font-size: clamp(32px, 4.5vw, 56px);
    line-height: 0.95;
    letter-spacing: -0.04em;
    font-weight: 900;
  }

  .home-heading__meta {
    max-width: 300px;
    margin: 0;
    font-size: 13px;
    color: var(--text-2);
  }

  .home-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .home-grid__feature {
    grid-column: span 2;
    grid-row: span 1;
  }

  .home-grid__feature :global(.post-card__title) {
    font-size: clamp(22px, 2.6vw, 30px);
  }

  .home-more {
    margin-top: var(--space-12);
    text-align: center;
  }

  @media (max-width: 1023px) {
    .home-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .home-grid__feature {
      grid-column: span 2;
    }
    .hero__content {
      grid-template-columns: 1fr;
    }
    .hero__side {
      display: none;
    }
  }

  @media (max-width: 639px) {
    .home-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .home-grid__feature {
      grid-column: span 1;
    }
    .home-heading {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
    .hero__index,
    .scroll-cue {
      display: none;
    }
  }
</style>
