  .protocol-modal { position: fixed; inset: 0; z-index: 5000; display: grid; place-items: center; opacity: 0; visibility: hidden; background: rgba(0,0,0,.82); backdrop-filter: blur(10px); transition: opacity 350ms,visibility 0s linear 350ms; }
  .protocol-modal.is-idle { display: none; }
  .protocol-modal.is-open { opacity: 1; visibility: visible; transition-delay: 0s; }
  .protocol-modal__box { width: min(1080px,calc(100vw - 36px)); aspect-ratio: 16/9; overflow: hidden; position: relative; border: 1px solid rgba(255,255,255,.35); background: #111517; color: #fff; clip-path: polygon(0 0,calc(100% - 30px) 0,100% 30px,100% 100%,30px 100%,0 calc(100% - 30px)); }
  .protocol-modal__visual { position: absolute; inset: 0; background: radial-gradient(circle at 70% 38%,rgba(244,246,0,.6),transparent 5%),repeating-radial-gradient(circle at 70% 38%,transparent 0 42px,rgba(244,246,0,.12) 43px 44px),linear-gradient(135deg,#818b8c,#1c2224 58%,#080a0b); animation: modal-pulse 4s ease-in-out infinite; animation-play-state: paused; }
  .protocol-modal__visual::before { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(0deg,transparent 0 4px,rgba(255,255,255,.03) 4px 5px); animation: scan-move 5s linear infinite; animation-play-state: paused; }
  .protocol-modal__copy { position: absolute; z-index: 2; inset: 12% 8%; width: 58%; }
  .protocol-modal__copy > .mono { color: var(--primary); font-size: 10px; }
  .protocol-modal__copy h2 { margin: 12px 0 18px; font-size: clamp(38px,5vw,72px); line-height: .92; }
