---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getFriends, getLatestDigest, getPosts, getSettingsCached, getTaxonomy } from '@/lib/api';
import { localePath, t, type Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const [postsRes, taxonomy, settings, friendsRes, digest] = await Promise.all([
  getPosts({ page: 1, pageSize: 3 }),
  getTaxonomy(),
  getSettingsCached(),
  getFriends(),
  getLatestDigest(),
]);

const ui = {
  zh: {
    eyebrow: '个人博客 / 越过边界',
    newsTitle: '最新情报',
    newsDescription: '由 AI 情报管线每日聚合的前沿信号，点击进入完整日报。',
    digestEmpty: '情报信号待接入 / 管线尚未生成日报',
    digestOpen: '阅读完整日报',
    carouselLabel: '重要情报轮播',
    carouselPrev: '上一组情报',
    carouselNext: '下一组情报',
    worldTitle: '内容疆域',
    worldDescription: '沿分类、系列与时间坐标进入博客的不同区域。',
    systemTitle: '内容部署系统',
    systemDescription: '通过文章网络、分类矩阵与全文扫描定位所需内容。',
    operatorTitle: '站点档案',
    operatorDescription: '读取博主、站点与连接网络的授权档案。',
    protocolTitle: '跨越边界\n直至下一篇记录',
    protocolDescription: '所有内容节点均已连接。选择一条路径，继续探索技术与生活的边界。',
    latest: '最新文章',
    enter: '进入博客',
    explore: '浏览全部文章',
    openProtocol: '打开站点协议',
    loading: '正在载入视觉协议',
    categories: '分类坐标',
    categoriesDesc: '按主题进入内容区域，沿知识边界定位相关记录。',
    series: '系列航线',
    seriesDesc: '沿连续写作计划阅读上下关联的完整内容。',
    archive: '时间档案',
    archiveDesc: '按发布时间回溯所有已公开记录和历史信号。',
    activeCategories: '有效分类',
    tags: '标签节点',
    posts: '公开文章',
    activeSeries: '有效系列',
    seriesEntries: '系列文章',
    latestYear: '最新年份',
    network: '文章网络',
    networkDesc: '读取全部公开文章，并从最新记录继续深入内容网络。',
    taxonomy: '分类矩阵',
    taxonomyDesc: '通过分类与标签交叉筛选，快速收窄内容范围。',
    scanner: '全文扫描',
    scannerDesc: '输入关键词，对已公开内容执行全文检索。',
    authorProfile: '博主档案',
    authorRole: 'AUTHOR / CONTROL',
    siteProfile: '关于本站',
    siteRole: 'SITE / PROTOCOL',
    connections: '连接网络',
    connectionsRole: 'FRIENDS / LINK',
    connectionsDesc: (count: number) => `当前已建立 ${count} 条友站连接，继续访问外部内容节点。`,
    readAbout: '读取关于档案',
    viewFriends: '查看连接网络',
    open: '进入区域',
    search: '开始扫描',
    status: '连接稳定',
    online: '在线',
    noPosts: '暂无公开信号',
    protocolReady: '协议就绪 / 内容节点在线',
    modalTitle: 'SaltedBlog 站点协议',
    modalLabel: 'AUTHORIZED CONTENT NETWORK',
    close: '关闭站点协议',
    scroll: '滚动',
  },
  en: {
    eyebrow: 'PERSONAL BLOG / OVER THE FRONTIER',
    newsTitle: 'Latest Intelligence',
    newsDescription: 'Frontier signals aggregated daily by the AI intel pipeline. Open the full digest.',
    digestEmpty: 'AWAITING INTEL SIGNAL / NO DIGEST GENERATED YET',
    digestOpen: 'Read Full Digest',
    carouselLabel: 'Important intelligence carousel',
    carouselPrev: 'Previous intelligence',
    carouselNext: 'Next intelligence',
    worldTitle: 'Content Frontier',
    worldDescription: 'Enter the archive through categories, series, and chronological coordinates.',
    systemTitle: 'Content Deployment System',
    systemDescription: 'Locate knowledge through the post network, taxonomy matrix, and full-text scanner.',
    operatorTitle: 'Site Personnel Archive',
    operatorDescription: 'Read the authorized records of the author, the site, and its network.',
    protocolTitle: 'Cross the Frontier\nToward the Next Record',
    protocolDescription: 'All content nodes are connected. Choose a path and continue beyond the frontier.',
    latest: 'Latest Posts',
    enter: 'Enter Blog',
    explore: 'Browse All Posts',
    openProtocol: 'Open Site Protocol',
    loading: 'Loading visual protocol',
    categories: 'Category Coordinates',
    categoriesDesc: 'Enter by topic and locate related records along the knowledge frontier.',
    series: 'Series Routes',
    seriesDesc: 'Follow continuous writing projects and read each connected entry in context.',
    archive: 'Time Archive',
    archiveDesc: 'Trace every published record and historical signal by release time.',
    activeCategories: 'ACTIVE CATEGORIES',
    tags: 'TAG NODES',
    posts: 'PUBLIC POSTS',
    activeSeries: 'ACTIVE SERIES',
    seriesEntries: 'SERIES POSTS',
    latestYear: 'LATEST YEAR',
    network: 'Post Network',
    networkDesc: 'Read every public post and move deeper into the network from the latest record.',
    taxonomy: 'Taxonomy Matrix',
    taxonomyDesc: 'Cross-filter categories and tags to narrow the content field.',
    scanner: 'Full-text Scanner',
    scannerDesc: 'Enter keywords and scan all public content for matching signals.',
    authorProfile: 'Author Profile',
    authorRole: 'AUTHOR / CONTROL',
    siteProfile: 'About the Site',
    siteRole: 'SITE / PROTOCOL',
    connections: 'Connection Network',
    connectionsRole: 'FRIENDS / LINK',
    connectionsDesc: (count: number) => `${count} external site connection${count === 1 ? '' : 's'} online. Continue to connected content nodes.`,
    readAbout: 'Read About File',
    viewFriends: 'View Connections',
    open: 'Enter Area',
    search: 'Start Scan',
    status: 'Connection Stable',
    online: 'Online',
    noPosts: 'No public signal',
    protocolReady: 'PROTOCOL READY / CONTENT NODES ONLINE',
    modalTitle: 'SaltedBlog Site Protocol',
    modalLabel: 'AUTHORIZED CONTENT NETWORK',
    close: 'Close site protocol',
    scroll: 'Scroll',
  },
}[lang];

const configured = (key: string, fallback: string) => settings[`${key}_${lang}`]?.trim() || fallback;
const siteTitle = settings[`site_title_${lang}`] || 'SaltedBlog';
const description = settings[`description_${lang}`] || '';
const author = settings.author || siteTitle;
const activeCategories = taxonomy.categories.filter((item) => (item.count ?? 0) > 0);
const activeTags = taxonomy.tags.filter((item) => (item.count ?? 0) > 0);
const activeSeries = taxonomy.series.filter((item) => (item.count ?? 0) > 0);
const seriesEntries = activeSeries.reduce((sum, item) => sum + (item.count ?? 0), 0);
const latestYear = postsRes.items[0]?.published_at
  ? new Date(postsRes.items[0].published_at!).getFullYear()
  : new Date().getFullYear();

const eyebrow = configured('home_eyebrow', ui.eyebrow);
const newsTitle = configured('home_news_title', ui.newsTitle);
const newsDescription = configured('home_news_description', ui.newsDescription);

// ---- AI 日报数据（最新情报区 + 滚动字幕） ----
const digestHref = digest ? localePath(lang, `/posts/${digest.slug}`) : '';
const digestTitle = digest?.title ?? '';
const digestSummary = digest?.summary ?? '';
// items 已按 importance 降序；小卡片每两条组成一页同步轮播。
const digestItems = (digest?.items ?? []).map((item, index) => ({
  title: item.title,
  summary: item.summary,
  source: item.source,
  stars: '★'.repeat(Math.min(Math.max(item.importance, 1), 5)),
  href: `${digestHref}#${item.anchor}`,
  art: (index % 2) + 2,
}));
const digestSlides = Array.from({ length: Math.ceil(digestItems.length / 2) }, (_, index) =>
  digestItems.slice(index * 2, index * 2 + 2)
);
const tickerHeadlines = (digest?.items ?? [])
  .slice(0, 5)
  .map(
    (item, index) =>
      `INTEL ${String(index + 1).padStart(2, '0')} / ${item.title}`
  );
const worldTitle = configured('home_world_title', ui.worldTitle);
const worldDescription = configured('home_world_description', ui.worldDescription);
const systemTitle = configured('home_system_title', ui.systemTitle);
const systemDescription = configured('home_system_description', ui.systemDescription);
const operatorTitle = configured('home_operator_title', ui.operatorTitle);
const operatorDescription = configured('home_operator_description', ui.operatorDescription);
const protocolTitle = configured('home_protocol_title', ui.protocolTitle);
const protocolDescription = configured('home_protocol_description', ui.protocolDescription);

const portals = [
  {
    id: '01',
    className: 'portal-art--categories',
    title: ui.categories,
    description: ui.categoriesDesc,
    href: localePath(lang, '/categories'),
    metrics: [
      [activeCategories.length, ui.activeCategories],
      [activeTags.length, ui.tags],
      [postsRes.total, ui.posts],
    ],
  },
  {
    id: '02',
    className: 'portal-art--series',
    title: ui.series,
    description: ui.seriesDesc,
    href: localePath(lang, '/series'),
    metrics: [
      [activeSeries.length, ui.activeSeries],
      [seriesEntries, ui.seriesEntries],
      [postsRes.total, ui.posts],
    ],
  },
  {
    id: '03',
    className: 'portal-art--archive',
    title: ui.archive,
    description: ui.archiveDesc,
    href: localePath(lang, '/archive'),
    metrics: [
      [latestYear, ui.latestYear],
      [postsRes.total, ui.posts],
      [activeTags.length, ui.tags],
    ],
  },
];
---

<BaseLayout lang={lang} variant="home">
  <div class="home-interface" id="homeInterface">
    <div class="home-boot" id="homeBoot" aria-label={ui.loading} aria-live="polite">
      <div class="home-boot__box">
        <div class="home-boot__mark">
          <span class="home-boot__glyph" aria-hidden="true"></span>
          <div>
            {siteTitle}
            <div class="home-boot__sub mono">INDUSTRIAL INTERFACE / SYSTEM BOOT</div>
          </div>
        </div>
        <div class="home-boot__bar"><i id="homeBootFill"></i></div>
        <div class="home-boot__meta mono">
          <span>{ui.loading}</span><b id="homeBootCount">000%</b>
        </div>
      </div>
    </div>

    <div class="home-cursor home-cursor--dot" id="homeCursorDot" aria-hidden="true"></div>
    <div class="home-cursor home-cursor--ring" id="homeCursorRing" aria-hidden="true"></div>

    <section class="hero" id="home-top">
      <canvas id="heroCanvas" aria-hidden="true"></canvas>
      <div class="hero__scene" aria-hidden="true"></div>
      <div class="terrain terrain--back" aria-hidden="true"></div>
      <div class="terrain terrain--front" aria-hidden="true"></div>
      <div class="hero__wash" aria-hidden="true"></div>
      <div class="hero__grid" aria-hidden="true"></div>
      <div class="container hero__content">
        <div class="hero__copy">
          <div class="hero__eyebrow mono" data-reveal>{eyebrow}</div>
          <h1 data-reveal="left">{siteTitle}<span>BLOG · TERMINAL</span></h1>
          {description && <p class="hero__desc" data-reveal>{description}</p>}
          <div class="hero__actions" data-reveal>
            <button class="home-btn home-btn--primary interactive" type="button" data-open-protocol>
              <span aria-hidden="true">▶</span> {ui.openProtocol}
            </button>
            <a class="home-btn home-btn--ghost interactive" href={localePath(lang, '/posts')}>
              {ui.explore} <span aria-hidden="true">↘</span>
            </a>
          </div>
        </div>
        <aside class="hero__side" data-reveal="right" aria-label="Blog statistics">
          <div class="hero__datum mono"><span>{ui.posts}</span><b>{String(postsRes.total).padStart(2, '0')}</b></div>
          <div class="hero__datum mono"><span>{ui.activeCategories}</span><b>{String(activeCategories.length).padStart(2, '0')}</b></div>
          <div class="hero__datum mono"><span>{ui.tags}</span><b>{String(activeTags.length).padStart(2, '0')}</b></div>
          <div class="hero__datum mono"><span>LINK STATUS</span><b>{ui.online}</b></div>
        </aside>
        <div class="hero__stamp mono" aria-hidden="true">PROTOCOL / BLOG / ONLINE</div>
      </div>
      <div class="hero__index mono" aria-hidden="true"><strong>00</strong><span>LANDING<br />PROTOCOL</span></div>
      <div class="scroll-cue mono" aria-hidden="true"><span>{ui.scroll}</span><i></i></div>
    </section>

    <div class="ticker" aria-hidden="true">
      <div class="ticker__track mono">
        {
          tickerHeadlines.length
            ? [0, 1].map(() => tickerHeadlines.map((headline) => <div class="ticker__item">{headline}</div>))
            : Array.from({ length: 4 }).map(() => (
                <div class="ticker__item">SALTEDBLOG / CONTENT NETWORK / SIGNAL CONNECTED / ARCHIVE ONLINE</div>
              ))
        }
      </div>
    </div>

    <section class="home-section home-section--grid" id="home-news">
      <div class="section-watermark mono" aria-hidden="true">INFORMATION</div>
      <div class="container">
        <header class="home-heading" data-reveal>
          <div class="home-heading__num mono">01 / NEWS</div>
          <h2>{newsTitle}</h2>
          <p>{newsDescription}</p>
        </header>
        {
          digest ? (
            <div class="news-grid">
              <article class="news-card news-card--feature interactive" data-reveal="left">
                <a class="news-card__visual" href={digestHref} aria-label={digestTitle}>
                  <span class="news-card__art news-card__art--1" />
                </a>
                <div class="news-card__body">
                  <div class="news-card__tag mono">
                    {digest.date} <span>/ {digest.item_count} SIGNALS</span>
                  </div>
                  <h3><a href={digestHref}>{digestTitle}</a></h3>
                  {digestSummary && <p>{digestSummary}</p>}
                  <a class="news-card__arrow" href={digestHref} aria-label={ui.digestOpen}>↗</a>
                </div>
              </article>
              <div
                class="news-carousel"
                data-news-carousel
                data-page-count={digestSlides.length}
                aria-label={ui.carouselLabel}
                aria-roledescription="carousel"
                data-reveal="right"
              >
                <div class="news-carousel__viewport" aria-live="off">
                  {digestSlides.map((slide, pageIndex) => (
                    <div
                      class="news-carousel__slide"
                      data-news-slide
                      data-active={pageIndex === 0 ? 'true' : 'false'}
                      hidden={pageIndex !== 0}
                      aria-label={`${pageIndex + 1} / ${digestSlides.length}`}
                    >
                      {slide.map((item) => (
                        <article class:list={['news-card', 'interactive', { 'news-card--wide': slide.length === 1 }]}>
                          <a class="news-card__visual" href={item.href} aria-label={item.title}>
                            <span class={`news-card__art news-card__art--${item.art}`} />
                          </a>
                          <div class="news-card__body">
                            <div class="news-card__tag mono">
                              {item.stars} {item.source && <span>/ {item.source}</span>}
                            </div>
                            <h3><a href={item.href}>{item.title}</a></h3>
                            {item.summary && <p>{item.summary}</p>}
                            <a class="news-card__arrow" href={item.href} aria-label={item.title}>↗</a>
                          </div>
                        </article>
                      ))}
                    </div>
                  ))}
                </div>
                {digestSlides.length > 1 && (
                  <div class="news-carousel__controls mono">
                    <button type="button" data-news-prev aria-label={ui.carouselPrev}>←</button>
                    <div class="news-carousel__dots">
                      {digestSlides.map((_, index) => (
                        <button
                          type="button"
                          data-news-dot={index}
                          data-active={index === 0 ? 'true' : 'false'}
                          aria-label={`${index + 1} / ${digestSlides.length}`}
                          aria-current={index === 0 ? 'true' : undefined}
                        />
                      ))}
                    </div>
                    <button type="button" data-news-next aria-label={ui.carouselNext}>→</button>
                  </div>
                )}
              </div>
            </div>
          ) : (
            <div class="home-empty mono" data-reveal>{ui.digestEmpty}</div>
          )
        }
        <div class="section-action" data-reveal>
          {digest && <a class="home-btn home-btn--primary" href={digestHref}>{ui.digestOpen} ↗</a>}
          <a class="home-btn" href={localePath(lang, '/posts')}>{t(lang, 'home.viewAll')} →</a>
        </div>
      </div>
    </section>

    <section class="world" id="home-world">
      <div class="world__sticky">
        <div class="world__back" aria-hidden="true"></div>
        <header class="world__header">
          <span class="mono">02 / WORLD DATA</span>
          <h2>{worldTitle}</h2>
          <p>{worldDescription}</p>
        </header>
        <div class="world__track" id="worldTrack">
          {portals.map((portal) => (
            <article class="world-panel">
              <a class:list={['world-panel__art', portal.className]} href={portal.href} aria-label={portal.title}></a>
              <div class="world-panel__copy">
                <div class="world-panel__no mono">AREA / {portal.id}</div>
                <h3>{portal.title}</h3>
                <p>{portal.description}</p>
                <div class="world-panel__data mono">
                  {portal.metrics.map(([value, label]) => (
                    <div><b class="counter" data-value={value}>0</b><span>{label}</span></div>
                  ))}
                </div>
                <a class="home-btn home-btn--ghost world-panel__action" href={portal.href}>{ui.open} ↗</a>
              </div>
            </article>
          ))}
        </div>
        <div class="world__progress" aria-hidden="true"><i id="worldProgress"></i></div>
      </div>
    </section>

    <section class="home-section home-section--grid" id="home-systems">
      <div class="section-watermark mono" aria-hidden="true">SYSTEM</div>
      <div class="container">
        <header class="home-heading" data-reveal>
          <div class="home-heading__num mono">03 / SYSTEM</div>
          <h2>{systemTitle}</h2>
          <p>{systemDescription}</p>
        </header>
        <div class="systems-layout" data-reveal>
          <div class="systems-visual">
            <canvas id="radarCanvas" aria-hidden="true"></canvas>
            <div class="systems-visual__hud" aria-hidden="true"></div>
          </div>
          <div class="systems-copy">
            <div class="system-tabs" role="tablist" aria-label={systemTitle}>
              <button
                class="system-tab is-active"
                type="button"
                role="tab"
                aria-selected="true"
                data-mode="network"
                data-action-href={localePath(lang, '/posts')}
                data-action-label={ui.explore}
              >
                <small class="mono">MODULE 01 / NETWORK · {postsRes.total}</small>
                <h3>{ui.network}</h3><p>{ui.networkDesc}</p>
              </button>
              <button
                class="system-tab"
                type="button"
                role="tab"
                aria-selected="false"
                data-mode="taxonomy"
                data-action-href={localePath(lang, '/categories')}
                data-action-label={ui.open}
              >
                <small class="mono">MODULE 02 / TAXONOMY · {activeCategories.length + activeTags.length}</small>
                <h3>{ui.taxonomy}</h3><p>{ui.taxonomyDesc}</p>
              </button>
              <button
                class="system-tab"
                type="button"
                role="tab"
                aria-selected="false"
                data-mode="scan"
                data-action-href={localePath(lang, '/search')}
                data-action-label={ui.search}
              >
                <small class="mono">MODULE 03 / SCANNING · READY</small>
                <h3>{ui.scanner}</h3><p>{ui.scannerDesc}</p>
              </button>
            </div>
            <div class="systems-action">
              <a class="home-btn" id="systemAction" href={localePath(lang, '/posts')}>{ui.explore} ↗</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="home-section operators" id="home-operators">
      <div class="section-watermark mono" aria-hidden="true">OPERATORS</div>
      <div class="container">
        <header class="home-heading" data-reveal>
          <div class="home-heading__num mono">04 / OPERATOR</div>
          <h2>{operatorTitle}</h2>
          <p>{operatorDescription}</p>
        </header>
        <div class="operator-stage" data-reveal>
          <div class="operator-list" role="tablist" aria-label={operatorTitle}>
            <button
              class="operator-btn is-active"
              type="button"
              role="tab"
              aria-selected="true"
              data-op="1"
              data-name={author}
              data-role={ui.authorRole}
              data-desc={description || operatorDescription}
              data-href={localePath(lang, '/about')}
              data-action={ui.readAbout}
            ><span class="operator-btn__id mono">01</span><span><b>{ui.authorProfile}</b><small>{ui.authorRole}</small></span></button>
            <button
              class="operator-btn"
              type="button"
              role="tab"
              aria-selected="false"
              data-op="2"
              data-name={siteTitle}
              data-role={ui.siteRole}
              data-desc={operatorDescription}
              data-href={localePath(lang, '/about')}
              data-action={ui.readAbout}
            ><span class="operator-btn__id mono">02</span><span><b>{ui.siteProfile}</b><small>{ui.siteRole}</small></span></button>
            <button
              class="operator-btn"
              type="button"
              role="tab"
              aria-selected="false"
              data-op="3"
              data-name={ui.connections}
              data-role={ui.connectionsRole}
              data-desc={ui.connectionsDesc(friendsRes.items.length)}
              data-href={localePath(lang, '/friends')}
              data-action={ui.viewFriends}
            ><span class="operator-btn__id mono">03</span><span><b>{ui.connections}</b><small>{friendsRes.items.length} LINKS</small></span></button>
          </div>
          <div class="operator-main" id="operatorMain" data-op="1">
            <div class="operator-silhouette" aria-hidden="true"></div>
            <div class="operator-copy">
              <div class="operator-copy__role mono" id="operatorRole">{ui.authorRole}</div>
              <h3 id="operatorName">{author}</h3>
              <p id="operatorDesc">{description || operatorDescription}</p>
              <a class="home-btn" id="operatorAction" href={localePath(lang, '/about')}>{ui.readAbout} ↗</a>
            </div>
            <div class="operator-code mono" aria-hidden="true">S.B. PERSONNEL ARCHIVE / AUTHORIZED</div>
          </div>
        </div>
      </div>
    </section>

    <section class="final-cta">
      <div class="final-cta__inner" data-reveal>
        <small class="mono">{ui.protocolReady}</small>
        <h2>{protocolTitle}</h2>
        <p>{protocolDescription}</p>
        <button class="home-btn home-btn--primary interactive" type="button" data-open-protocol>
          {ui.enter} ↗
        </button>
      </div>
    </section>

    <div class="protocol-modal is-idle" id="protocolModal" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="protocolTitle">
      <div class="protocol-modal__box" role="document">
        <div class="protocol-modal__visual" aria-hidden="true"></div>
        <button class="protocol-modal__close interactive" id="protocolClose" type="button" aria-label={ui.close}>×</button>
        <div class="protocol-modal__copy">
          <div class="mono">{ui.modalLabel}</div>
          <h2 id="protocolTitle">{ui.modalTitle}</h2>
          <p>{protocolDescription}</p>
          <div class="protocol-modal__stats mono">
            <span><b>{postsRes.total}</b>{ui.posts}</span>
            <span><b>{activeCategories.length}</b>{ui.activeCategories}</span>
            <span><b>{friendsRes.items.length}</b>LINKS</span>
          </div>
          <nav class="protocol-modal__links" aria-label={ui.modalTitle}>
            <a class="home-btn home-btn--primary" href={localePath(lang, '/posts')}>{ui.explore}</a>
