    background-size: 38px 38px;
    transition: opacity 700ms var(--ease), visibility 700ms;
  }

  .home-boot::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(0deg, transparent 0 3px, rgba(255, 255, 255, 0.018) 3px 4px);
    animation: scan-move 5s linear infinite;
  }

  :global(html[data-home-boot='skip']) .home-boot,
  .home-boot.is-done { opacity: 0; visibility: hidden; pointer-events: none; }
  .home-boot__box { width: min(560px, calc(100vw - 48px)); position: relative; }
  .home-boot__mark { display: flex; align-items: center; gap: 16px; margin-bottom: 38px; font-size: clamp(30px, 6vw, 62px); font-weight: 900; line-height: 0.9; }
  .home-boot__glyph { width: 56px; aspect-ratio: 1; flex: none; background: var(--primary); clip-path: polygon(50% 0, 100% 24%, 75% 50%, 100% 76%, 50% 100%, 0 76%, 25% 50%, 0 24%); animation: boot-glyph 1.2s steps(8) infinite; }
