  .home-boot__meta { display: flex; justify-content: space-between; margin-top: 10px; color: #9fa5a7; font-size: 10px; }

  .home-cursor { position: fixed; z-index: 9000; display: none; top: 0; left: 0; pointer-events: none; border-radius: 50%; }
  .home-cursor--dot { width: 5px; height: 5px; background: var(--primary); transform: translate3d(-100px,-100px,0) translate(-50%,-50%); box-shadow: 0 0 5px rgba(244,246,0,.65); }
  .home-cursor--ring { width: 34px; height: 34px; border: 1px solid rgba(244,246,0,.9); transform: translate3d(-100px,-100px,0) translate(-50%,-50%); transition: width 200ms,height 200ms,border-color 200ms; }
  .home-cursor--ring.is-active { width: 54px; height: 54px; border-color: var(--primary); }
  @media (hover: hover) and (pointer: fine) { .home-cursor { display: block; } }

  .hero { min-height: 100svh; position: relative; isolation: isolate; overflow: hidden; color: #fff; background: #92999b; }
  #heroCanvas { position: absolute; inset: 0; z-index: -1; width: 100%; height: 100%; }
  .hero__scene { position: absolute; inset: 0; z-index: -3; overflow: hidden; background: radial-gradient(circle at 73% 35%, rgba(244,246,0,.28), transparent 13%), radial-gradient(circle at 65% 48%, rgba(255,255,255,.55), transparent 20%), linear-gradient(120deg,#d9dddc 0%,#aeb5b6 42%,#555d60 78%,#202528 100%); }
  .hero__scene::before { content: ''; position: absolute; inset: -10%; background: linear-gradient(115deg,transparent 0 46%,rgba(11,13,15,.65) 46.2% 47.4%,transparent 47.6%), linear-gradient(115deg,transparent 0 56%,rgba(244,246,0,.86) 56.2% 57%,transparent 57.2%), repeating-linear-gradient(115deg,transparent 0 55px,rgba(11,13,15,.08) 56px 57px), radial-gradient(ellipse at 72% 60%,#dfe3df 0 10%,transparent 10.5%), radial-gradient(ellipse at 70% 58%,rgba(11,13,15,.88) 0 15%,transparent 15.5%); transform: translate(calc(var(--mx, 0) * -12px), calc(var(--my, 0) * -8px)) scale(1.08); transition: transform 100ms linear; }
