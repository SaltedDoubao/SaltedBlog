  .ticker { height: 44px; overflow: hidden; display: flex; align-items: center; border-block: 1px solid var(--black); background: var(--primary); color: var(--black); }
  .ticker__track { display: flex; width: max-content; animation: marquee 26s linear infinite; animation-play-state: paused; }
