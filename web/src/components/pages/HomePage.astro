  .operator-silhouette { position: absolute; left: 43%; top: 7%; width: 42%; height: 94%; transform: translateX(-50%); filter: drop-shadow(26px 24px 0 rgba(11,13,15,.15)); transition: clip-path 650ms var(--ease),background 400ms; background: linear-gradient(120deg,#f3f4ef 0 28%,#5e696b 28.5% 50%,#191f21 50.5% 72%,#f4f600 72.5%); clip-path: polygon(44% 0,58% 3%,67% 15%,65% 27%,77% 41%,73% 61%,89% 100%,50% 94%,12% 100%,27% 59%,23% 39%,36% 26%,33% 14%); }
