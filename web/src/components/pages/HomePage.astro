</BaseLayout>

<style>
  :global(body.home-page) {
    display: block;
    background: var(--bg);
    overflow-x: hidden;
  }

  :global(body.home-page.is-locked) { overflow: hidden; }
  :global(html[data-home-boot='play'] body.home-page) { overflow: hidden; }
