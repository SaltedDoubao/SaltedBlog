---
import { t, localePath, type Lang } from '@/i18n';
import type { SettingsMap } from '@/lib/api';

interface Props {
  lang: Lang;
  settings: SettingsMap;
}

const { lang, settings } = Astro.props;
const siteTitle = settings[`site_title_${lang}`] || 'SaltedBlog';
const year = new Date().getFullYear();
const github = settings.social_github;
const email = settings.social_email;
const icp = settings.icp;
const rssHref = lang === 'zh' ? '/rss.xml' : '/en/rss.xml';
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand-block">
        <div class="footer-brand">{siteTitle}</div>
        <div class="footer-sub mono">OVER THE FRONTIER / SINCE {year}</div>
      </div>
      <nav class="footer-links mono" aria-label="页脚导航">
        <a href={localePath(lang, '/posts')}>{t(lang, 'nav.posts')}</a>
        <a href={localePath(lang, '/archive')}>{t(lang, 'nav.archive')}</a>
        <a href={localePath(lang, '/friends')}>{t(lang, 'nav.friends')}</a>
        <a href={localePath(lang, '/about')}>{t(lang, 'nav.about')}</a>
        <a href={rssHref}>RSS</a>
        {github && <a href={github} target="_blank" rel="noopener">GITHUB</a>}
        {email && <a href={`mailto:${email}`}>EMAIL</a>}
      </nav>
    </div>
    <div class="footer-bottom mono">
      <span>© {year} {settings.author || siteTitle} / {t(lang, 'footer.builtWith')}</span>
      {icp && <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener">{icp}</a>}
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-24);
    padding: var(--space-12) 0 var(--space-8);
    background: var(--black);
    color: #aeb3b4;
    border-top: 1px solid #2e3335;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-10);
    align-items: start;
  }

  .footer-brand {
    font-size: 26px;
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.02em;
  }

  .footer-sub {
    margin-top: 6px;
    font-size: 9px;
    color: #6d7476;
  }

  .footer-links {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
    font-size: 11px;
    padding-top: 8px;
  }

  .footer-links a {
    text-decoration: none;
    color: #aeb3b4;
    transition: color var(--duration-fast) var(--ease);
  }

  .footer-links a:hover {
    color: var(--primary);
  }

  .footer-bottom {
    margin-top: var(--space-10);
    padding-top: var(--space-5);
    border-top: 1px solid #252a2c;
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    font-size: 9px;
    color: #6d7476;
  }

  .footer-bottom a {
    color: inherit;
    text-decoration: none;
  }

  .footer-bottom a:hover {
    color: var(--primary);
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
